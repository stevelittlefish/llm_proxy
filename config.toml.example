[server]
host = "0.0.0.0"
port = 11434
enable_cors = false
log_messages = true
log_raw_requests = false
log_raw_responses = false
verbose = false

[backend]
type = "openai"
endpoint = "http://localhost:8008"
timeout = 300
tool_blacklist = []

[backend_openai]
force_prompt_cache = false

[database]
path = "./data/llm_proxy.db"
max_requests = 100
cleanup_interval = 5

[request_sanitization]
# max_tokens_policy can be "preserve", "drop", or "drop_above"
max_tokens_policy = "preserve"
# Used only when max_tokens_policy = "drop_above"
max_tokens_limit = 0

[chat_text_injection]
enabled = false
text = "/nothink"
# mode can be "first", "last" or "system"
mode = "last"

[stream_override]
# Controls how the proxy talks to the backend, not what clients receive
# (clients always get back the format they requested).
# mode can be "passthrough", "always", or "never"
# "passthrough" asks the backend for whatever the client requested
# "always" always asks the backend to stream
# "never" always asks the backend for a single non-streamed response
mode = "passthrough"
